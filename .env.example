# Este es un archivo de ejemplo. Copia este archivo a .env y rellena los valores.
# El archivo .env NUNCA debe ser subido a un repositorio de Git.

# Cadena de conexión para la base de datos PostgreSQL
# Reemplaza <user>, <password>, <host>, <port> y <database> con tus credenciales.
PG_CONNECTION_STRING=postgresql://user:password@localhost:5432/ahorcado_db

# Puerto en el que se ejecutará el servidor web. Por defecto es 4000.
PORT=4000

# Secreto para firmar los JSON Web Tokens (JWT) para la autenticación.
JWT_SECRET=un_secreto_muy_largo_y_dificil_de_adivinar